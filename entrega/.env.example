# Segredos compartilhados
JWT_SECRET=super-secret-troque-isto
JWT_EXPIRES_IN=1h
INTERNAL_KEY=chave-interna-troque

# Portas dos serviços
USERS_PORT=5001
PRODUCTS_PORT=5002
PRODUCTS_REPLICA_PORT=5012
ORDERS_PORT=5003
GATEWAY_PORT=8080

# Heartbeat do gateway
HEARTBEAT_INTERVAL_MS=5000
HEARTBEAT_TIMEOUT_MS=2000
HEARTBEAT_MAX_RETRIES=2

# TLS/HTTPS entre serviços (true para ativar; rode "npm run certs" antes)
USE_TLS=false
